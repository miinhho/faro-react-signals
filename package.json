{
  "name": "faro-react-signals",
  "version": "0.1.0",
  "description": "Declarative React helpers for Grafana Faro.",
  "repository": {
    "type": "git",
    "url": "https://github.com/miinhho/faro-react-signals"
  },
  "packageManager": "pnpm@10.23.0",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "check": "biome check .",
    "format": "biome check --write .",
    "lint": "biome lint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepare": "husky"
  },
  "peerDependencies": {
    "@grafana/faro-web-sdk": "^1.10.0",
    "react": ">=18.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@grafana/faro-web-sdk": "^1.10.0",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitest/coverage-v8": "3.2.6",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsdown": "^0.22.2",
    "typescript": "^5.8.3",
    "vitest": "^3.0.8"
  }
}
